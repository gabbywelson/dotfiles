#!/bin/bash
# Bootstrap script - runs once before chezmoi applies dotfiles
# This installs all dependencies needed for the dotfiles to work

set -e  # Exit on error

echo ""
echo "=================================="
echo "  Setting up your dev environment"
echo "=================================="
echo ""

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[OK]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }

# ============================================
# Check macOS
# ============================================

if [[ "$(uname)" != "Darwin" ]]; then
    warn "This script is designed for macOS. Some things may not work."
fi

# ============================================
# Install Homebrew if needed
# ============================================

if ! command -v brew &> /dev/null; then
    info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
    success "Homebrew installed"
else
    success "Homebrew already installed"
fi

# ============================================
# Install packages from Brewfile
# ============================================

info "Installing packages from Brewfile (this may take a few minutes)..."
{{ $brewfile := joinPath .chezmoi.sourceDir "Brewfile" -}}
brew bundle --file="{{ $brewfile }}" --no-lock || true

success "Packages installed"

# ============================================
# Install Antidote (zsh plugin manager)
# ============================================

if [[ ! -d "$HOME/.antidote" ]]; then
    info "Installing Antidote plugin manager..."
    git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
    success "Antidote installed"
else
    success "Antidote already installed"
fi

# ============================================
# Create config directories
# ============================================

info "Creating config directories..."
mkdir -p "$HOME/.config/ghostty"
mkdir -p "$HOME/.config"
success "Directories ready"

# ============================================
# Done!
# ============================================

echo ""
echo "=================================="
echo -e "${GREEN}  Bootstrap complete!${NC}"
echo "=================================="
echo ""
echo "Next steps after chezmoi finishes:"
echo ""
echo "  1. Restart your terminal (or run: exec zsh)"
echo ""
echo "  2. Set your Git identity:"
echo "     git config --global user.name \"Your Name\""
echo "     git config --global user.email \"you@example.com\""
echo ""
echo "  3. In Ghostty, set font to: MesloLGS Nerd Font"
echo "     (Preferences > Font > MesloLGS Nerd Font)"
echo ""
